/*
 * Parolia Lab Ewings Sarcoma Pipeline
 * Nextflow Configuration File
 */

nextflow.enable.dsl = 2
conda.enabled = true

// ─────────────────────────────────────────────
// DEFAULT PARAMETERS
// ─────────────────────────────────────────────
params {

    // ── Reference genomes ──────────────────
    ref_hg38            = '/mctp/paroliaAnalysis/kevhu/genomes/hg38/hg38.fa'
    star_index          = '/mctp/paroliaAnalysis/kevhu/genomes/hg38_rna/STAR_genome_GRCh38_noALT_noHLA_noDecoy_ERCC_v39_oh100/'
    gtf                 = '/mctp/paroliaAnalysis/kevhu/genomes/hg38_rna/gencode.v39.GRCh38.ERCC.genes.stranded.gtf'

    // ── Sample sheets ──────────────────────
    rna_samplesheet     = '/mctp/paroliaAnalysis/kevhu/misc/RNAseqLibraries_EwingSarcoma.txt'


    // ── FASTQ input directories ────────────
    rna_fastq_dir       = '/mctp/paroliaAnalysis/kevhu/EwingsSarcoma/mergedFastq'


    // ── Output root ────────────────────────
    outdir              = '/mctp/paroliaAnalysis/kevhu/EwingsSarcoma/pipeline_out_claude'


    // ── Fusion calling ─────────────────────
    // STAR-Fusion CTAT genome library (download from STAR-Fusion GitHub releases)
    star_fusion_lib     = '/mctp/paroliaAnalysis/kevhu/genomes/GRCh38_CTAT_lib/GRCh38_gencode_v37_CTAT_lib_Mar012021.plug-n-play/ctat_genome_lib_build_dir'

    // ── Temporary directory ────────────────
    tmp_dir             = '/mctp/paroliaAnalysis/kevhu/tmp'
}

// ─────────────────────────────────────────────
// PROCESS RESOURCE LABELS
// ─────────────────────────────────────────────
process {
    // Default fallback
    cpus   = 1
    memory = '4.GB'
    time   = '2.h'

    withLabel: 'process_low' {
        cpus   = 2
        memory = '8.GB'
        time   = '4.h'
    }

    withLabel: 'process_medium' {
        cpus   = 8
        memory = '32.GB'
        time   = '12.h'
    }

    withLabel: 'process_high' {
        cpus   = 12
        memory = '48.GB'
        time   = '24.h'
    }

    withLabel: 'process_high_memory' {
        cpus   = 4
        memory = '64.GB'
        time   = '24.h'
    }

    // Scratch / temp dir for GATK
    scratch = params.tmp_dir
}

// ─────────────────────────────────────────────
// EXECUTOR  (current setup: single server, local)
// ─────────────────────────────────────────────
// Hard caps on the whole pipeline run.
// Nextflow schedules processes so the sum of running
// process.cpus and process.memory never exceeds these.
// Note: GATK/Picard uses -XX:+UseSerialGC so the JVM
// spawns no GC threads outside these declared allocations.
executor {
    name      = 'local'
    cpus      = 20    // hard cap: total cores across all running processes
    memory    = '200 GB'  // hard cap: total RAM across all running processes
    queueSize = 8     // max processes in-flight at once
}

// ─────────────────────────────────────────────
// PROFILES
// ─────────────────────────────────────────────
// To switch executors, run with: nextflow run main.nf -profile slurm
// The 'standard' profile (default) is the local single-server setup.
// The 'slurm' profile is for an HPC cluster with SLURM job scheduling.
profiles {

    standard {
        // ── Default: single server ─────────────────────────────────────
        // No changes needed. Uses the executor block above (local, 33 cpus).
        process.executor = 'local'
    }

    slurm {
        // ── To use this: nextflow run main.nf -profile slurm ───────────
        // What changes vs local:
        //   - Each process becomes a separate SLURM job (sbatch)
        //   - 'time' labels are enforced as wall-clock limits per job
        //   - 'memory' labels become --mem= SLURM directives
        //   - 'cpus' labels become --cpus-per-task= SLURM directives
        //   - clusterOptions passes extra #SBATCH flags (account, partition, etc.)
        //   - queueSize caps how many jobs sit in the SLURM queue at once
        //   - submitRateLimit prevents flooding the scheduler
        process.executor        = 'slurm'
        process.clusterOptions  = '--account=parolia'  // change to your SLURM account
        // process.queue        = 'standard'           // uncomment and set your partition name if needed
        executor.queueSize      = 50
        executor.submitRateLimit = '10/1min'

        // On SLURM the 'time' field in each label becomes a hard wall-clock
        // limit — jobs exceeding it are killed. Set conservatively.
        // On local executor, 'time' is ignored entirely.
    }

    // ── Other common schedulers (uncomment and adapt if needed) ────────
    // pbs {
    //     process.executor = 'pbspro'   // or 'pbs' for Torque
    //     process.clusterOptions = '-l nodes=1'
    //     executor.queueSize = 50
    // }
    // lsf {
    //     process.executor = 'lsf'
    //     process.clusterOptions = '-P parolia'
    //     executor.queueSize = 50
    // }
    // sge {
    //     process.executor = 'sge'
    //     executor.queueSize = 50
    // }
}

// ─────────────────────────────────────────────
// REPORTING
// ─────────────────────────────────────────────
report {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/reports/pipeline_report.html"
}

timeline {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/reports/pipeline_timeline.html"
}

dag {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/reports/pipeline_dag.svg"
}

// ─────────────────────────────────────────────
// MANIFEST
// ─────────────────────────────────────────────
manifest {
    name        = 'parolia-pdx-pipeline'
    description = 'PDX cancer genomics pipeline: xengsort → DNA/RNA processing'
    version     = '1.0.0'
    nextflowVersion = '>=23.04'
}
